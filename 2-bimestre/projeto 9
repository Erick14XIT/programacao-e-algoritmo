#include <iostream>
using namespace std;

int main() {
    int limite;

    cout << "Digite um numero entre 50 e 100: ";
    cin >> limite;

    if (limite < 50 || limite > 100) {
        cout << "Numero invalido!";
        return 0;
    }

    int a = 0, b = 1, proximo;

    cout << "Sequencia de Fibonacci: ";

    while (a <= limite) {
        cout << a << " ";
        proximo = a + b;
        a = b;
        b = proximo;
    }
